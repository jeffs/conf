#!/usr/bin/env -S zsh -euo pipefail

readonly width=$(($(tput cols) - 40))

echo '┌────────────┬──────────────────────┬────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐'
echo '│ Date       │ Name                 │ Subject                                                                                                                                                │'
echo '│────────────┼──────────────────────┼────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┤'
git --no-pager log --first-parent --format="│ %as │ %<(20)%an │ %<($width)%s │" "$@"
echo '└────────────┴──────────────────────┴────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘'
